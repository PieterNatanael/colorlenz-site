---
---

<footer>
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="footer-brand">ColorLenz</span>
      <span class="footer-copy">© 2026</span>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/privacy">Privacy Policy</a>
      <a href="/support">Support</a>
      <a href="/blog">Blog</a>
    </nav>

    <p class="footer-tagline">Made with care for brains that work differently.</p>
  </div>
</footer>

<style>
  footer {
    margin-top: 6rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-brand {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
  }

  .footer-copy {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--text-subtle);
    margin: 0;
  }

  @media (max-width: 720px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .footer-tagline {
      order: -1;
    }
  }
</style>
