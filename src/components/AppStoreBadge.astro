---
interface Props {
  class?: string;
}
import { APP_STORE_URL } from '../consts';
const { class: className = '' } = Astro.props;
---

<a
  href={APP_STORE_URL}
  class={`appstore-btn ${className}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Download ColorLenz on the Mac App Store"
>
  <!-- Apple logo -->
  <svg class="apple-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
    <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.14-2.15 1.26-2.13 3.75.03 2.99 2.63 3.99 2.66 4l-.08.28zM13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
  </svg>
  <div class="appstore-text">
    <span class="appstore-small">Download on the</span>
    <span class="appstore-large">Mac App Store</span>
  </div>
</a>

<style>
  .appstore-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #000;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    padding: 0.55rem 1.1rem;
    text-decoration: none;
    transition: all 160ms ease;
    white-space: nowrap;
  }

  .appstore-btn:hover {
    background: #1a1a1a;
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    color: #fff;
  }

  :global([data-theme='light']) .appstore-btn {
    background: #000;
    border-color: rgba(0, 0, 0, 0.15);
  }

  :global([data-theme='light']) .appstore-btn:hover {
    background: #1a1a1a;
  }

  .apple-icon {
    flex-shrink: 0;
    opacity: 0.95;
  }

  .appstore-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .appstore-small {
    font-family: var(--font-main);
    font-size: 9px;
    line-height: 1;
    opacity: 0.75;
    letter-spacing: 0.03em;
  }

  .appstore-large {
    font-family: var(--font-main);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
</style>
