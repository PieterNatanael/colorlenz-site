<script>
  const track = document.getElementById('screenshots-track') as HTMLElement | null;
  const dots = document.querySelectorAll('.dot-btn');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const total = 6;

  function getSlideWidth() {
    return (track?.firstElementChild as HTMLElement)?.offsetWidth ?? 0;
  }

  function currentIndex() {
    if (!track) return 0;
    return Math.round(track.scrollLeft / (getSlideWidth() + 24));
  }

  function goTo(i: number) {
    if (!track) return;
    const clamped = Math.max(0, Math.min(total - 1, i));
    track.scrollTo({ left: clamped * (getSlideWidth() + 24), behavior: 'smooth' });
  }

  // Update dots on scroll
  track?.addEventListener('scroll', () => {
    const i = currentIndex();
    dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
  }, { passive: true });

  // Dot clicks
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

  // Arrow buttons
  prevBtn?.addEventListener('click', () => goTo(currentIndex() - 1));
  nextBtn?.addEventListener('click', () => goTo(currentIndex() + 1));

  // Mouse drag on desktop
  let isDragging = false;
  let startX = 0;
  let startScrollLeft = 0;

  track?.addEventListener('mousedown', (e) => {
    isDragging = true;
    startX = e.pageX;
    startScrollLeft = track.scrollLeft;
    track.style.cursor = 'grabbing';
    track.style.userSelect = 'none';
  });

  document.addEventListener('mousemove', (e) => {
    if (!isDragging || !track) return;
    const dx = e.pageX - startX;
    track.scrollLeft = startScrollLeft - dx;
  });

  document.addEventListener('mouseup', () => {
    if (!isDragging || !track) return;
    isDragging = false;
    track.style.cursor = 'grab';
    track.style.userSelect = '';
    // Snap to nearest slide
    goTo(currentIndex());
  });

  // Set initial cursor
  if (track) track.style.cursor = 'grab';
</script>
