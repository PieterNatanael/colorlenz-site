---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AppStoreBadge from '../components/AppStoreBadge.astro';
import userImage from '../assets/userimage3.png';
import userImage2 from '../assets/userimage2.jpg';
import logo from '../assets/Goodmoodlogo.jpg';
import appstore1 from '../assets/appstore1.jpg';
import appstore2 from '../assets/appstore2.jpg';
import appstore3 from '../assets/appstore3.jpg';
import appstore4 from '../assets/appstore4.jpg';
import appstore5 from '../assets/appstore5.jpg';
import { SITE_TITLE, SITE_DESCRIPTION, APP_STORE_URL, WINDOWS_WAITLIST_FORM_ID } from '../consts';

// Get latest blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Goodmood — Screen Filter for Mac"
      description="Goodmood is a free screen filter for Mac that gently adjusts your screen color to reduce visual stimulation. Built for ADHD, autism, and sensory sensitivity. Download free on the Mac App Store."
    />
  </head>
  <body>
    <Header />
    <main>

      <!-- ── BRAND MOMENT ── -->
      <section class="brand-moment">
        <div class="container brand-moment-inner">
          <p class="bm-story">Once there was Light Mode.</p>
          <p class="bm-story">Then Dark Mode.</p>
          <p class="bm-headline">Now, Goodmood Mode.</p>
          <p class="bm-kicker">Your screen has had two modes for years.</p>
          <p class="bm-kicker">Maybe it's time for a third.</p>
          <p class="bm-kicker">↓</p>
          <p class="bm-kicker">Free for macOS</p>
        </div>
      </section>

      <hr class="pixel-divider" />

      <!-- ── FOUNDER NOTE ── -->
      <section class="founder-section">
        <div class="container">
          <div class="founder-note reveal">
            <div class="founder-note-header">
              <Image src={logo} alt="Goodmood" width={48} height={48} class="founder-logo" />
              <div>
                <p class="founder-label">From the founder</p>
                <p class="founder-name">Pieter, Goodmood</p>
              </div>
            </div>
            <p class="feeling-why">I built Goodmood because something always felt missing.</p>
            <p class="feeling-story">Hi, I'm Pieter. Like most people, I spent years switching between Light Mode and Dark Mode. Some days one felt better. Other days, neither did.</p>
            <p class="feeling-story">I kept wondering: why do we only have two choices? So I started experimenting. Every day, I'd make tiny adjustments to my screen until it felt just right for that moment.</p>
            <p class="feeling-story">I wasn't trying to build a company. I was simply trying to make my own screen feel better.</p>
            <p class="feeling-story">After using it every day for more than a month, I noticed something surprising. I didn't want to go back.</p>
            <p class="feeling-story">That's when I realized this might help other people too. Today, Goodmood is the app I use every time I sit in front of my Mac.</p>
            <p class="feeling-story">Maybe you'll feel the difference too.</p>
            <div class="founder-socials">
              <span class="founder-connect">Connect with Pieter</span>
              <a href="https://www.linkedin.com/in/pieternatanael" target="_blank" rel="noopener noreferrer" aria-label="Pieter on LinkedIn" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="https://x.com/PieterYNatanael" target="_blank" rel="noopener noreferrer" aria-label="Pieter on X" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- ── FEELING ── -->
      <section class="feeling">
        <div class="container feeling-inner">
          <Image src={logo} alt="Goodmood" width={288} height={288} class="feeling-logo reveal" />
          <div class="feeling-text reveal">
            <p>Every part of your day feels different.</p>
            <p>Your screen can too.</p>
            <p>Create a look for deep work. Another for reading. Another for late-night coding. Switch between them with one click.</p>
          </div>
        </div>
      </section>

      <hr class="pixel-divider" />

      <!-- ── HERO ── -->
      <section class="hero">
        <div class="container hero-inner">
          <div class="hero-text">
            <div class="badge hero-enter">macOS Screen Filter · Free to download</div>
            <h1 class="hero-enter-delay">Your screen can feel different.</h1>
            <p class="hero-sub hero-enter-delay">
              Not brighter. Not darker. Just... better.
            </p>
            <div class="hero-ctas hero-enter-delay-2">
              <AppStoreBadge />
              <p class="hero-pricing-note">
                Try Goodmood for yourself. Free to download. Personalize everything for just $0.99/month. Cancel anytime.
              </p>
            </div>
          </div>

          <div class="hero-image hero-enter-delay">
            <Image
              src={userImage}
              alt="Person using Goodmood with a green screen"
              width={480}
              height={480}
              class="user-img"
            />
          </div>
        </div>
      </section>


      <hr class="pixel-divider" />

      <!-- ── SCREENSHOTS ── -->
      <section class="screenshots-section">
        <div class="container reveal">
          <div class="section-label">See it in action</div>
          <h2>Can you spot the difference?</h2>
          <p class="section-sub">Most people can't. Until they try it.</p>
          <p class="section-sub">Real screenshots from Goodmood.</p>
        </div>

        <div class="screenshots-track" id="screenshots-track">
          {[
            { img: appstore1, label: "Goodmood in action" },
            { img: appstore2, label: "Goodmood in action" },
            { img: appstore3, label: "Goodmood in action" },
            { img: appstore4, label: "Goodmood in action" },
            { img: appstore5, label: "Goodmood in action" },
          ].map((item, i) => (
            <div class="screenshot-slide">
              <div class="mac-window">
                <div class="mac-chrome">
                  <span class="dot dot-red"></span>
                  <span class="dot dot-yellow"></span>
                  <span class="dot dot-green"></span>
                </div>
                <Image
                  src={item.img}
                  alt={item.label}
                  width={1280}
                  height={800}
                  class="screenshot-img"
                />
              </div>
              <p class="screenshot-label">{item.label}</p>
            </div>
          ))}
        </div>

        <div class="screenshots-controls">
          <button class="arrow-btn" id="prev-btn" aria-label="Previous screenshot">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>

          <div class="screenshots-dots" id="screenshots-dots">
            {[0,1,2,3,4,5,6,7].map((i) => (
              <button class={`dot-btn${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Screenshot ${i + 1}`}></button>
            ))}
          </div>

          <button class="arrow-btn" id="next-btn" aria-label="Next screenshot">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </section>

      <hr class="pixel-divider" />

      <!-- ── TESTIMONIALS ── -->
      <section class="testimonials">
        <div class="container">
          <div class="section-label reveal">From users</div>
          <div class="testimonials-header reveal">
            <p class="testimonials-sub">People didn't expect it either.</p>
            <a href="https://www.producthunt.com/products/goodmood-screen-companion?launch=goodmood-screen-companion" target="_blank" rel="noopener noreferrer" class="ph-link">
              <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="20" fill="#FF6154"/><path d="M22.5 20H17.5V15H22.5C23.88 15 25 16.12 25 17.5C25 18.88 23.88 20 22.5 20Z" fill="white"/><path d="M15 12.5H22.5C25.26 12.5 27.5 14.74 27.5 17.5C27.5 20.26 25.26 22.5 22.5 22.5H17.5V27.5H15V12.5Z" fill="white"/></svg>
              See more on Product Hunt
            </a>
          </div>
          <div class="testimonials-grid reveal-stagger">

            <blockquote class="testimonial reveal">
              <p>"Been using it for a week and the warmer tones in the evening really do feel gentler on my eyes during long coding sessions. Nice that you can dial it in yourself instead of being stuck with just light or dark."</p>
              <footer>
                <span class="testimonial-name">Selin</span>
              </footer>
            </blockquote>

            <blockquote class="testimonial reveal">
              <p>"Finally something beyond the usual light/dark toggle. Tried the warmer afternoon preset while reading docs and my eyes actually felt less strained within an hour."</p>
              <footer>
                <span class="testimonial-name">Miraç</span>
              </footer>
            </blockquote>

            <blockquote class="testimonial reveal">
              <p>"Love that you went beyond the binary light/dark choice and let people actually tune the screen to how their eyes feel."</p>
              <footer>
                <span class="testimonial-name">Berk</span>
              </footer>
            </blockquote>

          </div>
        </div>
      </section>

      <hr class="pixel-divider" />

      <!-- ── DOWNLOAD ── -->
      <section class="download" id="download">
        <div class="container download-inner reveal">
          <h2>You'll understand in about 30 seconds.</h2>
          <p class="download-sub">Free for macOS. No account required. Download.</p>
          <AppStoreBadge />
        </div>
      </section>

      <hr class="pixel-divider" />

      <!-- BLOG SECTION HIDDEN - posts under revision
      <section class="blog-section">
        <div class="container">
          <div class="section-label reveal">Learn & Explore</div>
          <h2 class="reveal">Latest from the blog</h2>
          <p class="section-sub reveal">Research-backed articles for neurodivergent focus and digital wellness</p>

          <div class="blog-grid reveal-stagger">
            {latestPosts.map((post) => (
              <article class="blog-card reveal">
                {post.data.heroImage && (
                  <a href={`/blog/${post.id}`} class="blog-image-link">
                    <Image
                      src={post.data.heroImage}
                      alt={post.data.title}
                      width={400}
                      height={225}
                      class="blog-image"
                    />
                  </a>
                )}
                <div class="blog-content">
                  <time datetime={post.data.pubDate.toISOString()} class="blog-date">
                    {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                  <h3>
                    <a href={`/blog/${post.id}`} class="blog-title-link">{post.data.title}</a>
                  </h3>
                  <p class="blog-description">{post.data.description}</p>
                  <a href={`/blog/${post.id}`} class="blog-link">Read article →</a>
                </div>
              </article>
            ))}
          </div>

          <div class="blog-cta">
            <a href="/blog" class="blog-view-all">View all articles</a>
          </div>
        </div>
      </section>
      -->

      <!-- Windows Waitlist -->
      <section class="windows-waitlist">
        <div class="container waitlist-inner">
          <div class="waitlist-content">
            <h3>Waiting for Windows?</h3>
            <p>Join the waitlist. We'll let you know as soon as it's ready.</p>
          </div>
          <form class="waitlist-form" id="windows-waitlist-form">
            <input type="hidden" name="form_type" value="windows-waitlist" />
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="waitlist-input"
            />
            <button type="submit" class="waitlist-btn">Notify me</button>
          </form>
          <p class="waitlist-success" id="windows-waitlist-success">You're on the list!</p>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>


<style>
  /* ── Section spacing ── */
  section {
    padding: 6rem 0;
  }

  /* ── Hero: pixel dot grid background ── */
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--pixel-dot);
    background-size: var(--pixel-dot-size);
    pointer-events: none;
    z-index: 0;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  /* ── Screenshots ── */
  .screenshots-section {
    padding-bottom: 5rem;
  }

  .screenshots-section .container {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .screenshots-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0 calc((100vw - min(900px, 90vw)) / 2);
    scrollbar-width: none;
  }

  .screenshots-track::-webkit-scrollbar {
    display: none;
  }

  .screenshot-slide {
    flex: 0 0 min(900px, 90vw);
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .mac-window {
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35), 0 4px 16px rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .mac-window:hover {
    border-color: var(--border-accent);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), var(--glow);
  }

  /* Subtle scanlines overlay */
  .mac-window::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 0, 0, 0.04) 3px,
      rgba(0, 0, 0, 0.04) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  .mac-chrome {
    background: #2a2a2a;
    padding: 0.55rem 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-bottom: 1px solid rgba(0,0,0,0.3);
  }

  [data-theme="light"] .mac-chrome {
    background: #e0e0e0;
    border-bottom: 1px solid #ccc;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }

  .screenshot-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .screenshot-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
    margin: 0;
  }

  .screenshots-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .arrow-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition);
    flex-shrink: 0;
  }

  .arrow-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: scale(1.05);
  }

  .screenshots-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }

  .dot-btn {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--border);
    cursor: pointer;
    padding: 0;
    transition: background var(--transition), transform var(--transition);
  }

  .dot-btn.active {
    background: var(--accent);
    transform: scale(1.3);
  }

  @media (max-width: 600px) {
    .screenshot-slide {
      flex: 0 0 92vw;
    }

    .screenshots-track {
      padding: 0 4vw;
    }
  }

  /* ── Hero ── */
  .hero {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(125, 211, 168, 0.2);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
  }

  .hero-pricing-note {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .appstore-badge {
    display: inline-block;
    transition: opacity var(--transition), transform var(--transition);
  }

  .appstore-badge:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .appstore-svg {
    display: block;
    width: 180px;
    height: auto;
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .user-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    border-radius: var(--radius);
    filter: drop-shadow(0 20px 60px rgba(125, 211, 168, 0.08));
  }

  /* ── Founder section ── */
  .founder-section {
    background: var(--bg);
  }

  /* ── Feeling ── */
  .founder-note {
    max-width: 640px;
    margin: 0 auto 3.5rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
  }

  .founder-note-header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .founder-logo {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    flex-shrink: 0;
  }

  .founder-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.15rem;
  }

  .founder-name {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
    margin: 0;
  }

  .feeling-why {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.7;
    margin: 0 0 0.85rem;
  }

  .feeling-story {
    font-size: 0.93rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin: 0 0 0.75rem;
  }

  .feeling-story:last-child {
    margin-bottom: 0;
  }

  .founder-socials {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  .founder-connect {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-right: 0.25rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-muted);
    transition: color var(--transition), border-color var(--transition);
  }

  .social-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .feeling {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .feeling-inner {
    display: flex;
    align-items: center;
    gap: 4rem;
  }

  .feeling-logo {
    width: 288px;
    height: 288px;
    border-radius: 56px;
    flex-shrink: 0;
    box-shadow: 0 16px 64px rgba(125, 211, 168, 0.12);
  }

  .feeling-text p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .feeling-text p:first-child {
    font-family: var(--font-pixel);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text);
    line-height: 2;
    margin-bottom: 1.5rem !important;
  }

  .feeling-kicker {
    font-size: 0.95rem !important;
    font-style: italic;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  @media (max-width: 720px) {
    .feeling-inner {
      flex-direction: column;
      gap: 2rem;
    }
    .feeling-logo {
      width: 160px;
      height: 160px;
      border-radius: 36px;
    }
  }

  /* ── Section label ── */
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
