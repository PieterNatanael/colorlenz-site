---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import userImage from '../assets/userimage.png';
import userImage2 from '../assets/userimage2.jpg';
import logo from '../assets/logo.png';
import { SITE_TITLE, SITE_DESCRIPTION, APP_STORE_URL } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- ── HERO ── -->
      <section class="hero">
        <div class="container hero-inner">
          <div class="hero-text">
            <div class="badge">macOS · Free to download</div>
            <h1>Built for brains that<br />work differently.</h1>
            <p class="hero-sub">
              A gentle floating lens that quietly adjusts your screen to match how
              you think, focus, and feel. No setup. No noise. Just your screen,
              working with you.
            </p>
            <div class="hero-ctas">
              <a href={APP_STORE_URL} class="appstore-badge" target="_blank" rel="noopener noreferrer" aria-label="Download ColorLenz on the Mac App Store">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 156 52" class="appstore-svg">
                  <rect width="156" height="52" rx="8" fill="black"/>
                  <rect width="155" height="51" rx="7.5" x="0.5" y="0.5" fill="none" stroke="white" stroke-opacity="0.3"/>
                  <!-- Apple logo -->
                  <path d="M22.5 17.2c1.1-1.4 1.9-3.3 1.7-5.2-1.6.1-3.6 1.1-4.7 2.5-1 1.2-1.9 3.1-1.7 5 1.8.1 3.6-1 4.7-2.3z" fill="white"/>
                  <path d="M24.2 19.8c-2.6-.2-4.8 1.5-6 1.5-1.3 0-3.2-1.4-5.3-1.4-2.7 0-5.2 1.6-6.6 4-2.8 4.9-.7 12.1 2 16.1 1.3 1.9 2.9 4 5 3.9 2-.1 2.7-1.3 5.1-1.3 2.4 0 3 1.3 5.1 1.2 2.2 0 3.5-1.9 4.8-3.8.9-1.3 1.6-2.8 2-4.3-3.3-1.3-4.8-4.8-4.8-8.1.1-2.9 1.4-5.5 3.7-7.1-.8-1-2.4-2.7-5-2.7z" fill="white"/>
                  <!-- Text: Download on the -->
                  <text x="40" y="22" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="10" fill="white" opacity="0.85">Download on the</text>
                  <!-- Text: Mac App Store -->
                  <text x="40" y="38" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="17" font-weight="600" fill="white">Mac App Store</text>
                </svg>
              </a>
              <p class="hero-pricing-note">
                Free to download. Unlock full personalization for $0.99/month, cancel anytime.
              </p>
            </div>
          </div>

          <div class="hero-image">
            <Image
              src={userImage}
              alt="Person using ColorLenz with a green screen"
              width={480}
              height={480}
              class="user-img"
            />
          </div>
        </div>
      </section>

      <!-- ── FEELING ── -->
      <section class="feeling">
        <div class="container feeling-inner">
          <Image src={logo} alt="ColorLenz" width={288} height={288} class="feeling-logo" />
          <div class="feeling-text">
            <p>Color is stimulation.<br />And stimulation adds up.</p>
            <p>
              ColorLenz gently turns down the noise your screen
              sends to your brain. Things get quieter. Calmer.
              A little more still.
            </p>
            <p class="feeling-kicker">Some call it dull. We call it breathing room.</p>
          </div>
        </div>
      </section>

      <!-- ── FEATURES ── -->
      <section class="features">
        <div class="container">
          <div class="section-label">Features</div>
          <h2>Everything you need.<br />Nothing you don't.</h2>
          <div class="screen-wrap">
            <Image
              src={userImage2}
              alt="Person using ColorLenz"
              width={900}
              class="screen-img"
            />
            <p class="screen-caption">Floating lens, sits gently on top of any app, any window</p>
          </div>
        </div>
      </section>

      <!-- ── DOWNLOAD ── -->
      <section class="download" id="download">
        <div class="container download-inner">
          <h2>Ready when you are.</h2>
          <p class="download-sub">Available now on macOS. Free to download.</p>
          <a href={APP_STORE_URL} class="appstore-badge" target="_blank" rel="noopener noreferrer" aria-label="Download ColorLenz on the Mac App Store">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 156 52" class="appstore-svg">
              <rect width="156" height="52" rx="8" fill="black"/>
              <rect width="155" height="51" rx="7.5" x="0.5" y="0.5" fill="none" stroke="white" stroke-opacity="0.3"/>
              <path d="M22.5 17.2c1.1-1.4 1.9-3.3 1.7-5.2-1.6.1-3.6 1.1-4.7 2.5-1 1.2-1.9 3.1-1.7 5 1.8.1 3.6-1 4.7-2.3z" fill="white"/>
              <path d="M24.2 19.8c-2.6-.2-4.8 1.5-6 1.5-1.3 0-3.2-1.4-5.3-1.4-2.7 0-5.2 1.6-6.6 4-2.8 4.9-.7 12.1 2 16.1 1.3 1.9 2.9 4 5 3.9 2-.1 2.7-1.3 5.1-1.3 2.4 0 3 1.3 5.1 1.2 2.2 0 3.5-1.9 4.8-3.8.9-1.3 1.6-2.8 2-4.3-3.3-1.3-4.8-4.8-4.8-8.1.1-2.9 1.4-5.5 3.7-7.1-.8-1-2.4-2.7-5-2.7z" fill="white"/>
              <text x="40" y="22" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="10" fill="white" opacity="0.85">Download on the</text>
              <text x="40" y="38" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="17" font-weight="600" fill="white">Mac App Store</text>
            </svg>
          </a>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>


<style>
  /* ── Section spacing ── */
  section {
    padding: 6rem 0;
  }

  /* ── Hero ── */
  .hero {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(125, 211, 168, 0.2);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
  }

  .hero-pricing-note {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .appstore-badge {
    display: inline-block;
    transition: opacity var(--transition), transform var(--transition);
  }

  .appstore-badge:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .appstore-svg {
    display: block;
    width: 180px;
    height: auto;
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .user-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    border-radius: var(--radius);
    filter: drop-shadow(0 20px 60px rgba(125, 211, 168, 0.08));
  }

  /* ── Feeling ── */
  .feeling {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .feeling-inner {
    display: flex;
    align-items: center;
    gap: 4rem;
  }

  .feeling-logo {
    width: 288px;
    height: 288px;
    border-radius: 56px;
    flex-shrink: 0;
    box-shadow: 0 16px 64px rgba(125, 211, 168, 0.12);
  }

  .feeling-text p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .feeling-text p:first-child {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.6;
  }

  .feeling-kicker {
    font-size: 0.95rem !important;
    font-style: italic;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  @media (max-width: 720px) {
    .feeling-inner {
      flex-direction: column;
      gap: 2rem;
    }
    .feeling-logo {
      width: 160px;
      height: 160px;
      border-radius: 36px;
    }
  }

  /* ── Section label ── */
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    margin-bottom: 2.5rem;
  }

  /* ── Presets ── */
  .presets {
    background: var(--bg);
  }

  .presets-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .presets-grid li {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1.1rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    transition: border-color var(--transition), background var(--transition);
    cursor: default;
  }

  .presets-grid li:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  /* ── Features ── */
  .features {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .screen-wrap {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 60%;
    margin-left: auto;
    margin-right: auto;
  }

  .screen-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: block;
  }

  .screen-caption {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-align: center;
    margin: 0;
  }

  .philosophy h2 {
    margin-bottom: 2rem;
  }

  .philosophy-body p {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.85;
  }

  .philosophy-goal {
    color: var(--text) !important;
    font-weight: 500;
    font-size: 1.15rem !important;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  /* ── Download ── */
  .download {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
  }

  .download-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .download-inner h2 {
    margin: 0;
  }

  .download-sub {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0 0 0.5rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-image {
      order: -1;
    }

    .user-img {
      max-width: 320px;
    }
  }

  @media (max-width: 720px) {
    section {
      padding: 4rem 0;
    }

    .hero {
      padding-top: 3rem;
      padding-bottom: 3rem;
    }

    .presets-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
