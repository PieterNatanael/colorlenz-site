---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import userImage from '../assets/userimage.png';
import userImage2 from '../assets/userimage2.jpg';
import logo from '../assets/logoaztec.png';
import cl1 from '../assets/Cl1.jpg';
import cl2 from '../assets/CL2.jpg';
import cl3 from '../assets/CL3.jpg';
import cl4 from '../assets/CL4.jpg';
import cl5 from '../assets/CL5.jpg';
import cl6 from '../assets/CL6.jpg';
import { SITE_TITLE, SITE_DESCRIPTION, APP_STORE_URL, WINDOWS_WAITLIST_FORM_ID } from '../consts';

// Get latest blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="ColorLenz — Screen Filter for Mac"
      description="ColorLenz is a free screen filter for Mac that gently adjusts your screen color to reduce visual stimulation. Built for ADHD, autism, and sensory sensitivity. Download free on the Mac App Store."
    />
  </head>
  <body>
    <Header />
    <main>

      <!-- ── HERO ── -->
      <section class="hero">
        <div class="container hero-inner">
          <div class="hero-text">
            <div class="badge">macOS Screen Filter · Free to download</div>
            <h1>Built for brains that<br />work differently.</h1>
            <p class="hero-sub">
              A gentle screen filter for Mac that quietly adjusts your screen color
              to match how you think, focus, and feel. No setup. No noise. Just
              your MacBook or Mac, working with you.
            </p>
            <div class="hero-ctas">
              <a href={APP_STORE_URL} class="appstore-badge" target="_blank" rel="noopener noreferrer" aria-label="Download ColorLenz on the Mac App Store">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 156 52" class="appstore-svg">
                  <rect width="156" height="52" rx="8" fill="black"/>
                  <rect width="155" height="51" rx="7.5" x="0.5" y="0.5" fill="none" stroke="white" stroke-opacity="0.3"/>
                  <!-- Apple logo -->
                  <path d="M22.5 17.2c1.1-1.4 1.9-3.3 1.7-5.2-1.6.1-3.6 1.1-4.7 2.5-1 1.2-1.9 3.1-1.7 5 1.8.1 3.6-1 4.7-2.3z" fill="white"/>
                  <path d="M24.2 19.8c-2.6-.2-4.8 1.5-6 1.5-1.3 0-3.2-1.4-5.3-1.4-2.7 0-5.2 1.6-6.6 4-2.8 4.9-.7 12.1 2 16.1 1.3 1.9 2.9 4 5 3.9 2-.1 2.7-1.3 5.1-1.3 2.4 0 3 1.3 5.1 1.2 2.2 0 3.5-1.9 4.8-3.8.9-1.3 1.6-2.8 2-4.3-3.3-1.3-4.8-4.8-4.8-8.1.1-2.9 1.4-5.5 3.7-7.1-.8-1-2.4-2.7-5-2.7z" fill="white"/>
                  <!-- Text: Download on the -->
                  <text x="40" y="22" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="10" fill="white" opacity="0.85">Download on the</text>
                  <!-- Text: Mac App Store -->
                  <text x="40" y="38" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="17" font-weight="600" fill="white">Mac App Store</text>
                </svg>
              </a>
              <p class="hero-pricing-note">
                Free to download. Unlock full personalization for $0.99/month, cancel anytime.
              </p>
            </div>
          </div>

          <div class="hero-image">
            <Image
              src={userImage}
              alt="Person using ColorLenz with a green screen"
              width={480}
              height={480}
              class="user-img"
            />
          </div>
        </div>
      </section>

      <hr class="pixel-divider" />

      <!-- ── FEELING ── -->
      <section class="feeling">
        <div class="container feeling-inner">
          <Image src={logo} alt="ColorLenz" width={288} height={288} class="feeling-logo" />
          <div class="feeling-text">
            <p>Color is stimulation.<br />And stimulation adds up.</p>
            <p>
              ColorLenz gently turns down the noise your screen
              sends to your brain. Things get quieter. Calmer.
              A little more still.
            </p>
            <p class="feeling-kicker">Some call it dull. We call it breathing room.</p>
          </div>
        </div>
      </section>


      <hr class="pixel-divider" />

      <!-- ── SCREENSHOTS ── -->
      <section class="screenshots-section">
        <div class="container">
          <div class="section-label">See it in action</div>
          <h2>Your screen, calmer.</h2>
          <p class="section-sub">Real screenshots from the app — every view, every feature.</p>
        </div>

        <div class="screenshots-track" id="screenshots-track">
          {[
            { img: cl1, label: "Floating lens over any app" },
            { img: cl2, label: "Color filter in action" },
            { img: cl3, label: "Privacy Mode" },
            { img: cl4, label: "Custom presets" },
            { img: cl5, label: "14 pill themes" },
            { img: cl6, label: "Works with everything" },
          ].map((item, i) => (
            <div class="screenshot-slide">
              <div class="mac-window">
                <div class="mac-chrome">
                  <span class="dot dot-red"></span>
                  <span class="dot dot-yellow"></span>
                  <span class="dot dot-green"></span>
                </div>
                <Image
                  src={item.img}
                  alt={item.label}
                  width={1280}
                  height={800}
                  class="screenshot-img"
                />
              </div>
              <p class="screenshot-label">{item.label}</p>
            </div>
          ))}
        </div>

        <div class="screenshots-controls">
          <button class="arrow-btn" id="prev-btn" aria-label="Previous screenshot">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>

          <div class="screenshots-dots" id="screenshots-dots">
            {[0,1,2,3,4,5].map((i) => (
              <button class={`dot-btn${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Screenshot ${i + 1}`}></button>
            ))}
          </div>

          <button class="arrow-btn" id="next-btn" aria-label="Next screenshot">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </section>

      <hr class="pixel-divider" />

      <!-- ── DOWNLOAD ── -->
      <section class="download" id="download">
        <div class="container download-inner">
          <h2>Ready when you are.</h2>
          <p class="download-sub">Available now on macOS. Free to download.</p>
          <a href={APP_STORE_URL} class="appstore-badge" target="_blank" rel="noopener noreferrer" aria-label="Download ColorLenz on the Mac App Store">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 156 52" class="appstore-svg">
              <rect width="156" height="52" rx="8" fill="black"/>
              <rect width="155" height="51" rx="7.5" x="0.5" y="0.5" fill="none" stroke="white" stroke-opacity="0.3"/>
              <path d="M22.5 17.2c1.1-1.4 1.9-3.3 1.7-5.2-1.6.1-3.6 1.1-4.7 2.5-1 1.2-1.9 3.1-1.7 5 1.8.1 3.6-1 4.7-2.3z" fill="white"/>
              <path d="M24.2 19.8c-2.6-.2-4.8 1.5-6 1.5-1.3 0-3.2-1.4-5.3-1.4-2.7 0-5.2 1.6-6.6 4-2.8 4.9-.7 12.1 2 16.1 1.3 1.9 2.9 4 5 3.9 2-.1 2.7-1.3 5.1-1.3 2.4 0 3 1.3 5.1 1.2 2.2 0 3.5-1.9 4.8-3.8.9-1.3 1.6-2.8 2-4.3-3.3-1.3-4.8-4.8-4.8-8.1.1-2.9 1.4-5.5 3.7-7.1-.8-1-2.4-2.7-5-2.7z" fill="white"/>
              <text x="40" y="22" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="10" fill="white" opacity="0.85">Download on the</text>
              <text x="40" y="38" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="17" font-weight="600" fill="white">Mac App Store</text>
            </svg>
          </a>
        </div>
      </section>

      <hr class="pixel-divider" />

      <!-- ── BLOG ── -->
      <section class="blog-section">
        <div class="container">
          <div class="section-label">Learn & Explore</div>
          <h2>Latest from the blog</h2>
          <p class="section-sub">Research-backed articles for neurodivergent focus and digital wellness</p>

          <div class="blog-grid">
            {latestPosts.map((post) => (
              <article class="blog-card">
                {post.data.heroImage && (
                  <a href={`/blog/${post.id}`} class="blog-image-link">
                    <Image
                      src={post.data.heroImage}
                      alt={post.data.title}
                      width={400}
                      height={225}
                      class="blog-image"
                    />
                  </a>
                )}
                <div class="blog-content">
                  <time datetime={post.data.pubDate.toISOString()} class="blog-date">
                    {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                  <h3>
                    <a href={`/blog/${post.id}`} class="blog-title-link">{post.data.title}</a>
                  </h3>
                  <p class="blog-description">{post.data.description}</p>
                  <a href={`/blog/${post.id}`} class="blog-link">Read article →</a>
                </div>
              </article>
            ))}
          </div>

          <div class="blog-cta">
            <a href="/blog" class="blog-view-all">View all articles</a>
          </div>
        </div>
      </section>

      <!-- Windows Waitlist -->
      <section class="windows-waitlist">
        <div class="container waitlist-inner">
          <div class="waitlist-content">
            <h3>Interested in Windows?</h3>
            <p>Leave your email and we'll let you know when it's available.</p>
          </div>
          <form class="waitlist-form" action={`https://formspree.io/f/${WINDOWS_WAITLIST_FORM_ID}`} method="POST">
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="waitlist-input"
            />
            <button type="submit" class="waitlist-btn">Notify me</button>
          </form>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>


<style>
  /* ── Section spacing ── */
  section {
    padding: 6rem 0;
  }

  /* ── Hero: pixel dot grid background ── */
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--pixel-dot);
    background-size: var(--pixel-dot-size);
    pointer-events: none;
    z-index: 0;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  /* ── Screenshots ── */
  .screenshots-section {
    padding-bottom: 5rem;
  }

  .screenshots-section .container {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .screenshots-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0 calc((100vw - min(900px, 90vw)) / 2);
    scrollbar-width: none;
  }

  .screenshots-track::-webkit-scrollbar {
    display: none;
  }

  .screenshot-slide {
    flex: 0 0 min(900px, 90vw);
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .mac-window {
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35), 0 4px 16px rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .mac-window:hover {
    border-color: var(--border-accent);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), var(--glow);
  }

  /* Subtle scanlines overlay */
  .mac-window::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 0, 0, 0.04) 3px,
      rgba(0, 0, 0, 0.04) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  .mac-chrome {
    background: #2a2a2a;
    padding: 0.55rem 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-bottom: 1px solid rgba(0,0,0,0.3);
  }

  [data-theme="light"] .mac-chrome {
    background: #e0e0e0;
    border-bottom: 1px solid #ccc;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }

  .screenshot-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .screenshot-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
    margin: 0;
  }

  .screenshots-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .arrow-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition);
    flex-shrink: 0;
  }

  .arrow-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: scale(1.05);
  }

  .screenshots-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }

  .dot-btn {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--border);
    cursor: pointer;
    padding: 0;
    transition: background var(--transition), transform var(--transition);
  }

  .dot-btn.active {
    background: var(--accent);
    transform: scale(1.3);
  }

  @media (max-width: 600px) {
    .screenshot-slide {
      flex: 0 0 92vw;
    }

    .screenshots-track {
      padding: 0 4vw;
    }
  }

  /* ── Hero ── */
  .hero {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(125, 211, 168, 0.2);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
  }

  .hero-pricing-note {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .appstore-badge {
    display: inline-block;
    transition: opacity var(--transition), transform var(--transition);
  }

  .appstore-badge:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .appstore-svg {
    display: block;
    width: 180px;
    height: auto;
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .user-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    border-radius: var(--radius);
    filter: drop-shadow(0 20px 60px rgba(125, 211, 168, 0.08));
  }

  /* ── Feeling ── */
  .feeling {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .feeling-inner {
    display: flex;
    align-items: center;
    gap: 4rem;
  }

  .feeling-logo {
    width: 288px;
    height: 288px;
    border-radius: 56px;
    flex-shrink: 0;
    box-shadow: 0 16px 64px rgba(125, 211, 168, 0.12);
  }

  .feeling-text p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .feeling-text p:first-child {
    font-family: var(--font-pixel);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text);
    line-height: 2;
    margin-bottom: 1.5rem !important;
  }

  .feeling-kicker {
    font-size: 0.95rem !important;
    font-style: italic;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  @media (max-width: 720px) {
    .feeling-inner {
      flex-direction: column;
      gap: 2rem;
    }
    .feeling-logo {
      width: 160px;
      height: 160px;
      border-radius: 36px;
    }
  }

  /* ── Section label ── */
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    margin-bottom: 2.5rem;
  }

  /* ── Presets ── */
  .presets {
    background: var(--bg);
  }

  .presets-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .presets-grid li {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1.1rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    transition: border-color var(--transition), background var(--transition);
    cursor: default;
  }

  .presets-grid li:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  /* ── Features ── */
  .features {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .screen-wrap {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 60%;
    margin-left: auto;
    margin-right: auto;
  }

  .screen-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: block;
  }

  .screen-caption {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-align: center;
    margin: 0;
  }

  .philosophy h2 {
    margin-bottom: 2rem;
  }

  .philosophy-body p {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.85;
  }

  .philosophy-goal {
    color: var(--text) !important;
    font-weight: 500;
    font-size: 1.15rem !important;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  /* ── Download ── */
  .download {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
  }

  .download-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .download-inner h2 {
    margin: 0;
  }

  .download-sub {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0 0 0.5rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-image {
      order: -1;
    }

    .user-img {
      max-width: 320px;
    }
  }

  @media (max-width: 720px) {
    .screen-wrap {
      max-width: 100%;
    }
  }

  /* ── Blog Section ── */
  .blog-section {
    background: var(--bg);
  }

  .blog-section h2 {
    margin-bottom: 0.5rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2rem;
    margin: 2.5rem 0;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-card);
    transition: all var(--transition);
  }

  .blog-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(125, 211, 168, 0.1);
  }

  .blog-image-link {
    display: block;
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--bg-subtle);
  }

  .blog-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition);
  }

  .blog-card:hover .blog-image {
    transform: scale(1.05);
  }

  .blog-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.5rem;
  }

  .blog-date {
