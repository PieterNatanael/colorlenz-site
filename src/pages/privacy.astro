---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Privacy Policy & Terms"
      description="ColorLenz / MoodLenz Privacy Policy and Terms of Use."
    />
  </head>
  <body>
    <Header />
    <main>
      <div class="container page-wrap">

        <header class="page-header">
          <div class="section-label">Legal</div>
          <h1>Privacy Policy &amp; Terms of Use</h1>
          <p class="page-intro">Plain language. No surprises.</p>
        </header>

        <div class="legal-toc">
          <a href="#terms">Terms of Use</a>
          <span aria-hidden="true">·</span>
          <a href="#privacy">Privacy Policy</a>
        </div>

        <div class="prose legal-prose">

          <!-- ── TERMS ── -->
          <h2 id="terms">Terms of Use</h2>
          <p class="last-updated">Last updated: May 1, 2026</p>

          <h3>Acceptance</h3>
          <p>
            By downloading or using ColorLenz / MoodLenz, you agree to these terms.
          </p>

          <h3>License</h3>
          <p>
            ColorLenz / MoodLenz grants you a personal, non-transferable, non-exclusive
            license to use the app on Apple devices you own or control, subject to the
            App Store Terms of Service.
          </p>

          <h3>Subscriptions</h3>
          <ul>
            <li>ColorLenz / MoodLenz Premium is available as a monthly or yearly auto-renewing subscription.</li>
            <li>Payment is charged to your Apple ID at confirmation of purchase.</li>
            <li>Subscriptions auto-renew unless cancelled at least 24 hours before the end of the current period.</li>
            <li>To cancel, go to <strong>Settings → [Your Name] → Subscriptions</strong>.</li>
            <li>No refunds are provided for partial subscription periods.</li>
          </ul>

          <h3>Permitted Use</h3>
          <p>
            You may use ColorLenz / MoodLenz for personal and professional purposes.
            You may not reverse-engineer, modify, or redistribute the app.
          </p>

          <h3>Disclaimer</h3>
          <p>
            ColorLenz / MoodLenz is provided "as is" without warranty of any kind.
            We are not liable for any damages arising from use of the app.
          </p>

          <h3>Governing Law</h3>
          <p>
            These terms are governed by the laws of the jurisdiction in which the
            developer is based.
          </p>

          <h3>Changes</h3>
          <p>
            We may update these terms at any time. Continued use of the app
            constitutes acceptance.
          </p>

          <h3>Contact</h3>
          <p>
            <a href="mailto:Pieternatanael@icloud.com">Pieternatanael@icloud.com</a>
          </p>

          <hr />

          <!-- ── PRIVACY ── -->
          <h2 id="privacy">Privacy Policy</h2>
          <p class="last-updated">Last updated: May 1, 2026</p>

          <h3>What We Collect</h3>
          <p>
            ColorLenz / MoodLenz does not collect, store, or transmit any personal data.
            The app captures your screen locally on your device solely to apply visual
            filters in real time. No screen content ever leaves your device.
          </p>

          <h3>Screen Recording</h3>
          <p>
            ColorLenz / MoodLenz requests Screen Recording permission to display a
            filtered live preview of your screen. This data is processed entirely
            on-device and is never saved, uploaded, or shared.
          </p>

          <h3>Subscription &amp; Payments</h3>
          <p>
            Subscriptions are handled entirely by Apple via the App Store. We do not
            have access to your payment information. For billing inquiries, visit
            <strong>Settings → [Your Name] → Subscriptions</strong> on your device.
          </p>

          <h3>Third-Party Services</h3>
          <p>
            We do not use any third-party analytics, advertising, or tracking SDKs.
          </p>

          <h3>Children</h3>
          <p>
            ColorLenz / MoodLenz is not directed at children under 13. We do not
            knowingly collect data from children.
          </p>

          <h3>Changes</h3>
          <p>
            We may update this policy occasionally. Continued use of the app
            constitutes acceptance of the updated policy.
          </p>

          <h3>Contact</h3>
          <p>
            <a href="mailto:Pieternatanael@icloud.com">Pieternatanael@icloud.com</a>
          </p>

        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-wrap {
    max-width: 720px;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .page-header h1 {
    margin-bottom: 0.5rem;
  }

  .page-intro {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0;
  }

  .legal-toc {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .legal-toc a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .last-updated {
    font-size: 0.8rem;
    color: var(--text-subtle);
    margin-top: -0.25rem;
    margin-bottom: 1.75rem;
  }

  .legal-prose h2 {
    font-size: 1.5rem;
    margin: 3rem 0 0.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .legal-prose h2:first-child {
    margin-top: 0;
  }

  .legal-prose h3 {
    font-size: 0.97rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.75rem 0 0.4rem;
  }

  .legal-prose p {
    font-size: 0.93rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .legal-prose ul {
    list-style: none;
    padding: 0;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .legal-prose li {
    font-size: 0.93rem;
    color: var(--text-muted);
    line-height: 1.7;
    padding-left: 1.1rem;
    position: relative;
  }

  .legal-prose li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--text-subtle);
  }

  .legal-prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal-prose strong {
    color: var(--text);
    font-weight: 500;
  }

  .legal-prose hr {
    margin: 3rem 0;
  }
</style>
