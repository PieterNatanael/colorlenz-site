---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Blog — Goodmood" description="Articles on screen comfort, focus, ADHD, and macOS from the Goodmood team." />
	</head>
	<body>
		<Header />
		<main>
			<div class="container page-wrap">

				<header class="page-header">
					<div class="section-label">Articles</div>
					<h1>Blog</h1>
					<p class="page-intro">Screen comfort, focus, neurodiversity, macOS, and technology.</p>
				</header>

				<!-- Featured post -->
				{featured && (
					<a href={`/blog/${featured.id}/`} class="featured-post reveal">
						{featured.data.heroImage && (
							<div class="featured-image">
								<Image width={1020} height={480} src={featured.data.heroImage} alt={featured.data.title} />
							</div>
						)}
						<div class="featured-body">
							<p class="post-date"><FormattedDate date={featured.data.pubDate} /></p>
							<h2 class="post-title">{featured.data.title}</h2>
							<p class="post-desc">{featured.data.description}</p>
						</div>
					</a>
				)}

				<!-- Rest of posts grid -->
				{rest.length > 0 && (
					<div class="posts-grid reveal-stagger">
						{rest.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card reveal">
								{post.data.heroImage && (
									<div class="post-image">
										<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									</div>
								)}
								<div class="post-body">
									<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-desc">{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				)}

			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-wrap {
		padding-top: 4rem;
		padding-bottom: 4rem;
	}

	.page-header {
		margin-bottom: 3rem;
	}

	.page-intro {
		font-size: 1.05rem;
		color: var(--text-muted);
		margin: 0;
	}

	/* Featured post */
	.featured-post {
		display: block;
		text-decoration: none;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		margin-bottom: 3rem;
		transition: border-color var(--transition), box-shadow var(--transition);
	}

	.featured-post:hover {
		border-color: var(--border-accent);
		box-shadow: var(--glow);
	}

	.featured-image img {
		width: 100%;
		height: 360px;
		object-fit: cover;
		display: block;
	}

	.featured-body {
		padding: 1.75rem 2rem;
	}

	/* Post grid */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.post-card {
		display: block;
		text-decoration: none;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		transition: border-color var(--transition), box-shadow var(--transition);
	}

	.post-card:hover {
		border-color: var(--border-accent);
		box-shadow: var(--glow);
	}

	.post-image img {
		width: 100%;
		height: 200px;
		object-fit: cover;
		display: block;
	}

	.post-body {
		padding: 1.25rem;
	}

	/* Shared text styles */
	.post-date {
		font-size: 0.78rem;
		color: var(--text-subtle);
		margin: 0 0 0.5rem;
	}

	.post-title {
		color: var(--text);
		margin: 0 0 0.5rem;
		word-break: break-word;
		overflow-wrap: break-word;
	}

	.featured-body .post-title {
		font-size: clamp(0.85rem, 2vw, 1.1rem);
	}

	.post-desc {
		font-size: 0.88rem;
		color: var(--text-muted);
		line-height: 1.65;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* Tablet */
	@media (max-width: 860px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* Mobile */
	@media (max-width: 560px) {
		.featured-image img {
			height: 220px;
		}

		.featured-body {
			padding: 1.25rem;
		}

		.posts-grid {
			grid-template-columns: 1fr;
		}

		.post-image img {
			height: 180px;
		}
	}
</style>
