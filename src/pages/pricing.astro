---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { APP_STORE_URL } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Pricing"
      description="ColorLenz is free to download. Unlock full personalization for $0.99/month, cancel anytime."
    />
  </head>
  <body>
    <Header />
    <main>
      <div class="container page-wrap">

        <header class="page-header">
          <div class="section-label">Pricing</div>
          <h1>Free to use. $0.99 to make it yours.</h1>
          <p class="page-intro">Try it with the defaults. Pay only when you want to personalize.</p>
        </header>

        <div class="pricing-grid">

          <!-- Free tier -->
          <div class="pricing-card">
            <div class="pricing-card-top">
              <span class="tier-badge free">Free</span>
              <div class="pricing-price">
                <span class="price-amount">$0</span>
                <span class="price-period">forever</span>
              </div>
              <p class="pricing-desc">The lens works the moment you open it. No strings.</p>
            </div>
            <ul class="pricing-features">
              <li><span class="check">✓</span> Floating lens, always on</li>
              <li><span class="check">✓</span> Default color settings</li>
              <li><span class="check">✓</span> Privacy Mode</li>
              <li><span class="check">✓</span> Ad-free</li>
              <li><span class="check">✓</span> No account needed</li>
            </ul>
            <a href={APP_STORE_URL} class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              Download free
            </a>
          </div>

          <!-- Full Access tier -->
          <div class="pricing-card pricing-card-highlight">
            <div class="pricing-card-top">
              <span class="tier-badge paid">Full Access</span>
              <div class="pricing-price">
                <span class="price-amount">$0.99</span>
                <span class="price-period">/ month</span>
              </div>
              <p class="pricing-desc">Personalize everything. Make the lens feel like you.</p>
            </div>
            <ul class="pricing-features">
              <li><span class="check">✓</span> Everything in Free</li>
               <li><span class="check">✓</span>Full access to customization</li>
              <li><span class="check">✓</span> All 7 mood presets</li>
              <li><span class="check">✓</span> 14 pill themes</li>
              <li><span class="check">✓</span> Custom preset builder</li>
              <li><span class="check">✓</span> Cancel anytime</li>
            </ul>
            <a href={APP_STORE_URL} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              Start free, then unlock
            </a>
          </div>

        </div>

        <div class="pricing-note">
          <p>
            Pricing shown in USD. Actual price may vary by country, as set by the App Store.
          </p>
          <p>
            Subscriptions are handled by Apple. Cancel anytime from
            <strong>Settings → [Your Name] → Subscriptions</strong> on your device.
            No refunds for partial periods.
          </p>
          <p>
            Questions? <a href="mailto:Pieternatanael@icloud.com">Pieternatanael@icloud.com</a>
          </p>
        </div>

      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-wrap {
    max-width: 760px;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .page-header h1 {
    margin-bottom: 0.5rem;
  }

  .page-intro {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .pricing-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pricing-card-highlight {
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .pricing-card-top {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tier-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    width: fit-content;
  }

  .tier-badge.free {
    background: var(--bg-subtle);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .tier-badge.paid {
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid rgba(125, 211, 168, 0.3);
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .price-amount {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .price-period {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .pricing-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
    padding: 0;
    margin: 0;
  }

  .pricing-features li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  .pricing-card-highlight .pricing-features li {
    color: var(--text);
  }

  .check {
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .pricing-note {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }

  .pricing-note p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 0.5rem;
    line-height: 1.7;
  }

  .pricing-note p:last-child {
    margin: 0;
  }

  .pricing-note strong {
    color: var(--text);
    font-weight: 500;
  }

  .pricing-note a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 560px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
